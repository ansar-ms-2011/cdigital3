{
  "buildCommand": "npm run build",
  "framework": "vite",
  "outputDirectory": "./dist/client",
  "functions": {
    "api/ssr.ts": {
      "maxDuration": 30,
      "memory": 1024
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/ssr"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/assets/$1",
      "headers": {
        "cache-control": "public, max-age=31536000, immutable"
      }
    },
    {
      "src": "/(.*)",
      "dest": "/api/ssr"
    }
  ]
}
